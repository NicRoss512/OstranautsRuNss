  },
  {
    "strName": "ENCHeatGalConFineEnd",
    "strTitle": "Ходатайствуйте о штрафе (единовременном)",
    "strDesc": "Это почти как если бы они хотели, чтобы вы нарушили правила, чтобы они могли взыскать с вас больше штрафов.\n\nТы подписываешь кипы бумаг в тугих наручниках.\n\nЭто тюремный срок другого рода. Еще один груз висит у тебя на шее.\n\nДобавлен новый штраф в размере 15 000 долларов.",
    "strColor": "Dialogue",
    "aInverse": [
      "ENCHeatGalConFineFinish"
    ],
    "fDuration": 0.0,
    "strThemType": "Self",
    "strRaiseUI": "SocialCombat",
    "strSubUI": "Landscape01",
    "strImage": "encounters/EncFirstUndockFees",
    "nLogging": 0,
    "bPause": true,
    "bHumanOnly": true,
    "bIgnoreFeelings": true,
    "strLedgerDef": "ENCHeatGalConFinePublicDisorder",
    "aSocialNew": []
  },
  {
    "strName": "ENCHeatGalConFineDebtEnd",
    "strTitle": "Требовать штрафа (выплачиваемого частями)",
    "strDesc": "Это почти как если бы они хотели, чтобы вы нарушили правила, чтобы они могли еще больше привязать вас к выплате процентов.\n\nТы подписываешь кипы бумаг в тугих наручниках.\n\nЭто тюремный срок другого рода. Еще один груз висит у тебя на шее.\n\nДобавлен новый долг в размере 15 000 долларов, который подлежит оплате каждую смену.",
    "strColor": "Dialogue",
    "aInverse": [
      "ENCHeatGalConFineFinish"
    ],
    "fDuration": 0.0,
    "strThemType": "Self",
